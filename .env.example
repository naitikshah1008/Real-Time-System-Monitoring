# Copy this file to .env for local runs or self-hosted demos.
# Keep .env out of Git.

# Bind host-exposed ports to localhost by default.
LOCAL_BIND_ADDRESS=127.0.0.1

# Host ports.
DEMO_API_PORT=8000
GRAFANA_PORT=3000
KAFKA_UI_PORT=8080
SCHEMA_REGISTRY_PORT=8081
KAFKA_EXTERNAL_PORT=29092
POSTGRES_PORT=5432
ZOOKEEPER_PORT=2181

# Kafka host listener used only by tools running outside Docker.
KAFKA_ADVERTISED_HOST=localhost

# Database credentials. Change these outside local-only runs.
POSTGRES_USER=rtm
POSTGRES_PASSWORD=rtm
POSTGRES_DB=rtm

# Grafana credentials. Change these outside local-only runs.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Demo simulator settings.
HOST_ID=demo-host-1
METRICS_SOURCE=simulator

# Pipeline behavior.
FRESH_METRIC_SECONDS=60
FLINK_GROUP_ID=rtm-flink-anomaly
FLINK_PARALLELISM=1
FLINK_STARTING_OFFSET=latest
PROCESSOR_HEALTH_PORT=8090
